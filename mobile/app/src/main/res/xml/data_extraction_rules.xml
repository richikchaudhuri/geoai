<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data-transfer rules. Excludes app prefs from cloud backup
    AND device-to-device transfer. The user's last-known location, recent
    cooldown timestamp, and theme prefs are not worth syncing across
    devices and could leak captured-at-night locations if a backup is
    exfiltrated.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="msc_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="msc_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
