<?xml version="1.0" encoding="utf-8"?>
<!--
    Apple ATS-equivalent for Android. Locks the app to:
      - TLS 1.2+ only (no plaintext, no SSLv3, no TLS 1.0/1.1)
      - Certificates issued by trusted system CAs only
      - Specific domains needed by GeoAI; everything else is implicitly denied
        because we set usesCleartextTraffic="false" in the manifest

    NOTE: We deliberately don't pin specific cert public-key hashes here.
    Cloudinary, Supabase, and Google Play Services rotate their certs on
    schedule. Hard-pinning would brick the app whenever they rotate.
    Instead, we trust system CAs which is what every well-behaved app does.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Domains we know we need. Anything else is still TLS-only,
         but explicitly listing these documents the surface and lets
         us add per-domain pins later if we want. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">cloudinary.com</domain>
        <domain includeSubdomains="true">gstatic.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
