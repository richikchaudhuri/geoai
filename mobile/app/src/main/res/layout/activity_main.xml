<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".MainActivity">

    <!-- Camera Preview (drawn first, behind everything) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="89dp"
        android:background="@color/bar_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- GEO text -->
        <TextView
            android:id="@+id/roadText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GEO"
            android:textColor="@color/bar_text"
            android:textSize="50sp"
            android:fontFamily="@font/rostex_outline"
            android:textStyle="normal"
            android:includeFontPadding="false"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- AI text -->
        <TextView
            android:id="@+id/senseText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI"
            android:textColor="@color/bar_text"
            android:textSize="25sp"
            android:fontFamily="@font/sf_display_bold"
            android:textStyle="normal"
            android:includeFontPadding="false"
            app:layout_constraintStart_toEndOf="@id/roadText"
            app:layout_constraintBaseline_toBaselineOf="@id/roadText" />

        <!-- Location button -->
        <ImageButton
            android:id="@+id/locationButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_location"
            android:contentDescription="Location"
            android:scaleType="fitCenter"
            android:padding="4dp"
            app:tint="@color/bar_icon_tint"
            app:layout_constraintEnd_toStartOf="@id/settingsButton"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:scaleType="fitCenter"
            android:padding="4dp"
            app:tint="@color/bar_icon_tint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Location notification pill (floating, rounded, detached from top bar) -->
    <LinearLayout
        android:id="@+id/locationPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/location_pill_bg"
        android:visibility="gone"
        android:elevation="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:clipToOutline="true"
        android:outlineProvider="background"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Collapsed pill row: green dot + "Location Online" -->
        <LinearLayout
            android:id="@+id/locationCollapsedRow"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/greenDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/green_dot" />

            <TextView
                android:id="@+id/locationStatusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Location Online"
                android:textColor="#FF4CAF50"
                android:textSize="20sp"
                android:fontFamily="@font/sf_display_light"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- Expanded details (initially gone) -->
        <LinearLayout
            android:id="@+id/locationExpandedDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- Thin divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/pill_divider"
                android:layout_marginBottom="14dp" />

            <!-- OSM Map (clipped rounded) with offline overlay -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/map_card_bg">

                <org.osmdroid.views.MapView
                    android:id="@+id/locationMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="false"
                    android:focusable="false" />

                <!-- Blurred overlay for offline state -->
                <FrameLayout
                    android:id="@+id/mapOfflineOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/map_offline_overlay"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="Turn on Location"
                        android:textColor="@color/map_offline_text"
                        android:textSize="16sp"
                        android:fontFamily="@font/sf_display_light" />

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- Coordinates -->
            <TextView
                android:id="@+id/locationCoordinates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0000, 0.0000"
                android:textColor="@color/pill_subtitle"
                android:textSize="16sp"
                android:fontFamily="@font/sf_display_light"
                android:letterSpacing="0.05"
                android:layout_marginBottom="6dp" />

            <!-- Address -->
            <TextView
                android:id="@+id/locationAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fetching address..."
                android:textColor="@color/pill_address"
                android:textSize="18sp"
                android:fontFamily="@font/sf_display_light"
                android:layout_marginBottom="6dp" />

            <!-- Time -->
            <TextView
                android:id="@+id/locationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/pill_time"
                android:textSize="14sp"
                android:fontFamily="@font/sf_display_light" />

        </LinearLayout>

    </LinearLayout>

    <!-- Flash status pill (drops from top, auto-dismisses) -->
    <TextView
        android:id="@+id/flashPill"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="@drawable/cooldown_pill_bg"
        android:text="Flash off"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="22sp"
        android:fontFamily="@font/sf_display_light"
        android:elevation="12dp"
        android:visibility="gone"
        android:layout_marginTop="36dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Shutter cooldown pill (drops from top, same spot as location pill) -->
    <TextView
        android:id="@+id/cooldownPill"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="@drawable/cooldown_pill_bg"
        android:text="Wait 6s"
        android:textColor="#FFF44336"
        android:textSize="25sp"
        android:fontFamily="@font/sf_display_light"
        android:elevation="12dp"
        android:visibility="gone"
        android:layout_marginTop="36dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Upload notification pill -->
    <LinearLayout
        android:id="@+id/uploadPill"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="28dp"
        android:background="@drawable/upload_pill_bg"
        android:elevation="12dp"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Circular progress / status icon container -->
        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="14dp">

            <!-- Yellow spinning progress -->
            <ProgressBar
                android:id="@+id/uploadProgress"
                style="?android:attr/progressBarStyle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:indeterminateTint="#FFFFC107"
                android:visibility="visible" />

            <!-- Green circle bg for success -->
            <View
                android:id="@+id/uploadSuccessBg"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/ic_upload_success"
                android:visibility="gone" />

            <!-- Check icon on green -->
            <ImageView
                android:id="@+id/uploadCheckIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/ic_check"
                app:tint="#FFFFFFFF"
                android:scaleType="centerInside"
                android:visibility="gone" />

            <!-- Red circle bg for failure -->
            <View
                android:id="@+id/uploadFailBg"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/ic_upload_fail"
                android:visibility="gone" />

            <!-- Cross icon on red -->
            <ImageView
                android:id="@+id/uploadCrossIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="8dp"
                android:src="@drawable/ic_cross"
                app:tint="#FFFFFFFF"
                android:scaleType="centerInside"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/uploadPillText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Image Uploading"
            android:textColor="@color/pill_text"
            android:textSize="25sp"
            android:fontFamily="@font/sf_display_light" />

    </LinearLayout>

    <!-- Footer box -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/bar_background"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- PHOTO label -->
        <TextView
            android:id="@+id/photoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PHOTO"
            android:textColor="@color/photo_label"
            android:textSize="17sp"
            android:fontFamily="@font/sf_display_light"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingBottom="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/shutterButton"
            app:layout_constraintVertical_chainStyle="packed" />

        <!-- Thumbnail button -->
        <ImageView
            android:id="@+id/thumbnailButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="24dp"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:background="@drawable/thumbnail_placeholder"
            android:contentDescription="Last photo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/shutterButton"
            app:layout_constraintBottom_toBottomOf="@id/shutterButton" />

        <!-- Flash toggle (off / on / auto) — sized to match the thumbnail -->
        <ImageButton
            android:id="@+id/flashButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="24dp"
            android:padding="4dp"
            android:src="@drawable/ic_flash_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:contentDescription="Toggle flash"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/shutterButton"
            app:layout_constraintBottom_toBottomOf="@id/shutterButton" />

        <!-- Shutter button (ring + animated inner) -->
        <FrameLayout
            android:id="@+id/shutterButton"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="Take photo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/photoLabel">

            <!-- Static outer ring -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shutter_ring" />

            <!-- Animated inner circle -->
            <View
                android:id="@+id/shutterInner"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:layout_gravity="center"
                android:background="@drawable/shutter_inner" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
